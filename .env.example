# 复制本文件为 .env 并填入真实值（.env 不会被提交到 git）

# ===== 模型与接入（阿里云百炼 compatible-mode）=====
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://your-endpoint/compatible-mode/v1

# 高德地图 key
GAODE_KEY=your-gaode-key

# ===== 大模型调用 =====
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ===== 鉴权 / 限流 / CORS =====
# 设置后 /api/chat 与 /api/admin/reload 需带 ?key=... 才能访问；留空则不校验（本地开发）
APP_API_KEY=
# 单客户端（IP+会话）每分钟允许的对话请求数
RATE_LIMIT_PER_MIN=20
# 允许的跨域来源，逗号分隔；* 表示全部
ALLOWED_ORIGINS=*

# ===== 记忆 =====
# SQLite 记忆存储文件路径
MEMORY_DB_PATH=checkpoints.sqlite
# 会话空闲多少分钟后清理其记忆（<=0 表示不清理）
SESSION_TTL_MINUTES=180
# 历史消息超过多少条触发摘要压缩，压缩后保留最近多少条
SUMMARY_TRIGGER_MESSAGES=30
SUMMARY_KEEP_MESSAGES=12
# 单次对话内模型最多调用轮数（防工具死循环）
MODEL_RUN_LIMIT=12
