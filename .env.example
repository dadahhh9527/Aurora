# Copy this file to .env and fill in real values (.env is git-ignored).

# ===== Model provider =====
# Works with any OpenAI-compatible endpoint (OpenAI, Azure OpenAI, local models, etc.).
OPENAI_API_KEY=replace-with-provider-api-key

# Defaults to OpenAI models. Override to use a different provider:
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: point at any OpenAI-compatible endpoint instead of OpenAI.
#   Azure OpenAI:     https://<resource>.openai.azure.com/openai/deployments/<name>
#   Local (Ollama):   http://localhost:11434/v1
#   Alibaba Bailian:  https://<endpoint>/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# Some endpoints cap embedding batch size; lower this if you hit a 400 error.
# EMBEDDING_BATCH_SIZE=10

# Optional reranker (e.g. DashScope gte-rerank); only used if rerank_enabled: true in chroma.yml
# RERANK_API_KEY=

# ===== Weather tool (OpenWeatherMap) =====
# Free key: https://openweathermap.org/api  (leave empty to disable the weather tool)
OPENWEATHER_API_KEY=

# Optional private usage-data file. Use a *.local.csv path so Git ignores it.
# EXTERNAL_DATA_PATH=data/external/records.local.csv

# ===== LLM call reliability =====
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ===== Runtime mode / local accounts =====
# true: no login, deterministic demo business users 1001-1010. Never enable in production.
APP_DEBUG=false
# SQLite database for users, login sessions, conversation ownership and long-term memory
APP_DB_PATH=aurora.sqlite
# Local login session lifetime and password policy
AUTH_SESSION_HOURS=12
MIN_PASSWORD_LENGTH=10
# Set true behind HTTPS in production
COOKIE_SECURE=false
# Max chat requests per authenticated user + client IP per minute
RATE_LIMIT_PER_MIN=20
LOGIN_RATE_LIMIT_PER_MIN=10
# Allowed CORS origins, comma-separated.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ===== Conversational memory =====
# SQLite file for persistent memory
MEMORY_DB_PATH=checkpoints.sqlite
# Clear a session's memory after this many idle minutes (<=0 to keep forever)
SESSION_TTL_MINUTES=180
# Summarize history after this many messages, keeping the most recent N
SUMMARY_TRIGGER_MESSAGES=30
SUMMARY_KEEP_MESSAGES=12
# Max model calls per turn (guards against tool loops)
MODEL_RUN_LIMIT=12

# ===== User long-term memory =====
LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_LIMIT=30
LONG_TERM_MEMORY_EXTRACT_LIMIT=5
LONG_TERM_MEMORY_MIN_CONFIDENCE=0.8

# ===== Automatic local knowledge-base scan =====
KB_SCAN_ENABLED=true
KB_SCAN_INTERVAL_SECONDS=600
# Optional persistent paths (useful for containers)
# CHROMA_DB_PATH=runtime/chroma_db
# KNOWLEDGE_DATA_PATH=data/private
# KB_MANIFEST_PATH=runtime/kb_manifest.json
