# Copy this file to .env and fill in real values (.env is git-ignored).

# ===== Model provider =====
# Works with any OpenAI-compatible endpoint (OpenAI, Azure OpenAI, local models, etc.).
OPENAI_API_KEY=sk-your-openai-api-key

# Defaults to OpenAI models. Override to use a different provider:
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: point at any OpenAI-compatible endpoint instead of OpenAI.
#   Azure OpenAI:     https://<resource>.openai.azure.com/openai/deployments/<name>
#   Local (Ollama):   http://localhost:11434/v1
#   Alibaba Bailian:  https://<endpoint>/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# Some endpoints cap embedding batch size; lower this if you hit a 400 error.
# EMBEDDING_BATCH_SIZE=10

# Optional reranker (e.g. DashScope gte-rerank); only used if rerank_enabled: true in chroma.yml
# RERANK_API_KEY=

# ===== Weather tool (OpenWeatherMap) =====
# Free key: https://openweathermap.org/api  (leave empty to disable the weather tool)
OPENWEATHER_API_KEY=

# ===== LLM call reliability =====
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ===== Auth / rate limit / CORS =====
# When set, /api/chat and /api/admin/reload require ?key=... ; empty disables auth (local dev).
APP_API_KEY=
# Max chat requests per client (IP + session) per minute
RATE_LIMIT_PER_MIN=20
# Allowed CORS origins, comma-separated; * means all
ALLOWED_ORIGINS=*

# ===== Conversational memory =====
# SQLite file for persistent memory
MEMORY_DB_PATH=checkpoints.sqlite
# Clear a session's memory after this many idle minutes (<=0 to keep forever)
SESSION_TTL_MINUTES=180
# Summarize history after this many messages, keeping the most recent N
SUMMARY_TRIGGER_MESSAGES=30
SUMMARY_KEEP_MESSAGES=12
# Max model calls per turn (guards against tool loops)
MODEL_RUN_LIMIT=12
